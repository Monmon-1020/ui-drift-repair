  "meta": {
    "source": "https://github.blog/changelog/2025-09-29-strengthening-npm-security-important-changes-to-authentication-and-token-management/",
    "drift_type": "step_insertion",
    "patch_type": "INSERT_STEP",
    "commit": null,
    "change_date": "2025-10-01",
    "rationale": "npm security changes now require two-factor authentication (2FA) for all package publishing operations. Previously, users could publish packages directly with just their credentials. The new workflow requires enabling 2FA (steps s2) and entering an OTP code during publish (step s4), adding two new steps to the publishing process. This prevents unauthorized package publishes and protects against account compromise.",
    "insertion_details": {
      "inserted_after_step": "s1",
      "num_steps_added": 2,
      "reason": "Security requirement - 2FA must be enabled and OTP provided for all package publishes"
    }
  },
