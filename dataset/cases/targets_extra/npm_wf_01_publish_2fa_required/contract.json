          "WebAuthn"
        ]
      }
    },
    {
      "step_id": "s3",
      "action": {
        "type": "cli_command",
        "command": "npm publish"
      },
      "anchor": {
        "role": "command",
        "name": "npm publish",
        "signature": {
          "container_kind": "terminal",
          "section_path": [
            "npm CLI"
          ],
          "context_text": [
